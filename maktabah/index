<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>المكتبة — Al-Maktabah Bidayatuna</title>
<style>
:root {
  --hijau:       #1b4332;
  --hijau-md:    #2d6a4f;
  --hijau-muda:  #40916c;
  --hijau-pale:  #d8f3dc;
  --hijau-xpale: #f0faf2;
  --emas:        #92620a;
  --emas-md:     #b7950b;
  --emas-pale:   #fef9e7;
  --emas-border: #e6c96a;
  --biru:        #1a3a5c;
  --biru-pale:   #e8f0fa;
  --abu:         #f4f3ef;
  --abu-tua:     #6b7280;
  --border:      #d1d5db;
  --teks:        #1a1a1a;
  --merah:       #dc2626;
  --merah-pale:  #fef2f2;
  --putih:       #ffffff;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Segoe UI', system-ui, sans-serif;
  background: var(--abu);
  color: var(--teks);
  min-height: 100vh;
  direction: rtl;
}

/* ===== HEADER ===== */
.header {
  background: var(--hijau);
  color: white;
  padding: 0 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 56px;
  position: sticky;
  top: 0;
  z-index: 40;
  box-shadow: 0 2px 8px rgba(0,0,0,0.18);
}
.header-brand {
  display: flex;
  align-items: center;
  gap: 10px;
}
.header-brand .logo {
  font-family: 'Traditional Arabic', serif;
  font-size: 1.5rem;
  color: var(--emas-border);
  line-height: 1;
}
.header-brand .nama {
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.01em;
}
.header-brand .sub {
  font-size: 0.65rem;
  opacity: 0.7;
  font-weight: 400;
  margin-top: 1px;
}
.btn-tambah-header {
  background: var(--emas-border);
  color: var(--hijau);
  border: none;
  border-radius: 8px;
  padding: 8px 16px;
  font-size: 0.82rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.15s;
  white-space: nowrap;
}
.btn-tambah-header:hover { background: #f5d87a; }

/* ===== HALAMAN UTAMA — DAFTAR KITAB ===== */
#halamanDaftar { display: block; }
#halamanBaca   { display: none; }

.container { max-width: 860px; margin: 0 auto; padding: 20px 16px; }

/* EMPTY STATE */
.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: var(--abu-tua);
}
.empty-state .icon {
  font-size: 3.5rem;
  margin-bottom: 14px;
  display: block;
  font-family: 'Traditional Arabic', serif;
  color: var(--emas-border);
}
.empty-state h2 {
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 6px;
  color: var(--teks);
}
.empty-state p { font-size: 0.8rem; line-height: 1.6; }

/* GRID KITAB */
.grid-kitab {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 14px;
}
.kartu-kitab {
  background: var(--putih);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  transition: box-shadow 0.2s, transform 0.15s;
  cursor: pointer;
  position: relative;
}
.kartu-kitab:hover {
  box-shadow: 0 4px 18px rgba(27,67,50,0.13);
  transform: translateY(-2px);
}
.kartu-spine {
  height: 6px;
  background: linear-gradient(90deg, var(--hijau-md), var(--hijau-muda));
}
.kartu-body { padding: 14px; }
.kartu-arab {
  font-family: 'Traditional Arabic', 'Scheherazade New', serif;
  font-size: 1.2rem;
  line-height: 1.8;
  color: var(--hijau);
  margin-bottom: 2px;
  direction: rtl;
}
.kartu-judul {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--teks);
  margin-bottom: 4px;
  direction: ltr;
  text-align: left;
}
.kartu-meta {
  font-size: 0.68rem;
  color: var(--abu-tua);
  line-height: 1.5;
  direction: ltr;
  text-align: left;
}
.kartu-badge {
  display: inline-block;
  background: var(--hijau-pale);
  color: var(--hijau-md);
  border-radius: 20px;
  padding: 2px 8px;
  font-size: 0.62rem;
  font-weight: 600;
  margin-top: 6px;
}
.kartu-actions {
  display: flex;
  gap: 6px;
  padding: 10px 14px;
  border-top: 1px solid var(--border);
  background: var(--abu);
  direction: ltr;
}
.btn-kartu {
  flex: 1;
  border: 1px solid var(--border);
  background: var(--putih);
  border-radius: 6px;
  padding: 6px;
  font-size: 0.68rem;
  cursor: pointer;
  color: var(--abu-tua);
  transition: all 0.15s;
  text-align: center;
}
.btn-kartu:hover { border-color: var(--hijau-muda); color: var(--hijau-md); }
.btn-kartu.buka {
  background: var(--hijau);
  color: white;
  border-color: var(--hijau);
  font-weight: 700;
}
.btn-kartu.buka:hover { background: var(--hijau-md); }
.btn-kartu.hapus:hover { border-color: var(--merah); color: var(--merah); }

/* ===== PANEL BACA ===== */
.baca-header {
  background: var(--hijau);
  color: white;
  padding: 10px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
  direction: ltr;
}
.btn-back {
  background: rgba(255,255,255,0.15);
  border: none;
  border-radius: 6px;
  color: white;
  padding: 6px 12px;
  font-size: 0.8rem;
  cursor: pointer;
  flex-shrink: 0;
}
.btn-back:hover { background: rgba(255,255,255,0.25); }
.baca-judul-wrap { flex: 1; direction: rtl; }
.baca-judul-arab {
  font-family: 'Traditional Arabic', serif;
  font-size: 1.1rem;
  line-height: 1.6;
}
.baca-judul-latin { font-size: 0.7rem; opacity: 0.75; margin-top: 1px; }

/* TOGGLE BAR */
.toggle-bar {
  background: var(--putih);
  border-bottom: 1px solid var(--border);
  padding: 9px 14px;
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  align-items: center;
  direction: ltr;
  position: sticky;
  top: 56px;
  z-index: 30;
}
.tog {
  font-size: 0.67rem;
  padding: 4px 10px;
  border-radius: 20px;
  border: 1px solid var(--border);
  background: var(--putih);
  cursor: pointer;
  transition: all 0.15s;
  color: var(--abu-tua);
  white-space: nowrap;
}
.tog.on {
  background: var(--hijau-pale);
  border-color: var(--hijau-muda);
  color: var(--hijau-md);
  font-weight: 600;
}
.tog-sep { width: 1px; height: 18px; background: var(--border); margin: 0 2px; }
.mode-label { font-size: 0.62rem; color: var(--abu-tua); }

.baca-toolbar {
  background: var(--abu);
  border-bottom: 1px solid var(--border);
  padding: 7px 14px;
  display: flex;
  gap: 6px;
  align-items: center;
  direction: ltr;
  flex-wrap: wrap;
}
.btn-toolbar {
  border: 1px solid var(--border);
  background: var(--putih);
  border-radius: 6px;
  padding: 5px 12px;
  font-size: 0.72rem;
  cursor: pointer;
  color: var(--abu-tua);
  transition: all 0.15s;
  white-space: nowrap;
}
.btn-toolbar:hover { border-color: var(--hijau-muda); color: var(--hijau-md); }
.btn-toolbar.edit-mode { background: #fff7ed; border-color: #f97316; color: #c2410c; font-weight: 600; }
.btn-toolbar.export-btn { background: var(--hijau); color: white; border-color: var(--hijau); font-weight: 700; }
.btn-toolbar.export-btn:hover { background: var(--hijau-md); }
.btn-toolbar.export-btn.reminder {
  animation: pulseExport 1.5s ease-in-out infinite;
  position: relative;
}
.btn-toolbar.export-btn.reminder::after {
  content: '!';
  position: absolute;
  top: -5px;
  left: -5px;
  background: var(--merah);
  color: white;
  width: 16px; height: 16px;
  border-radius: 50%;
  font-size: 0.6rem;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}
@keyframes pulseExport {
  0%, 100% { box-shadow: 0 0 0 0 rgba(220,38,38,0.4); }
  50% { box-shadow: 0 0 0 6px rgba(220,38,38,0); }
}

/* ===== KONTEN INTERLINEAR ===== */
.baca-content { padding: 0; }

.halaman-block {
  border-bottom: 2px solid var(--hijau-pale);
  padding: 18px 16px;
}
.halaman-block:last-child { border-bottom: none; }

.halaman-label {
  font-size: 0.68rem;
  color: var(--abu-tua);
  margin-bottom: 12px;
  border-right: 3px solid var(--hijau-muda);
  padding-right: 8px;
  direction: rtl;
}
.bab-title {
  font-family: 'Traditional Arabic', 'Scheherazade New', serif;
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--hijau);
  text-align: center;
  margin-bottom: 14px;
  line-height: 2;
}

.kalimat-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 14px;
  direction: rtl;
  justify-content: flex-start;
  padding: 12px;
  background: var(--hijau-xpale);
  border-radius: 8px;
  margin-bottom: 8px;
}

/* KATA UNIT */
.kata-unit {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  min-width: 42px;
  max-width: 130px;
  border-radius: 6px;
  padding: 3px 4px;
  transition: background 0.15s;
}
.kata-unit.edit-active {
  background: #fff7ed;
  outline: 2px solid #f97316;
  cursor: pointer;
}
.kata-unit.edit-active:hover { background: #ffedd5; }

/* KODE GRAMATIKAL — pill badge */
.kode-gram-wrap {
  display: flex;
  gap: 2px;
  flex-wrap: wrap;
  justify-content: center;
  min-height: 18px;
}
.kg-pill {
  font-size: 0.55rem;
  color: white;
  background: var(--hijau-md);
  border-radius: 20px;
  padding: 1px 6px;
  font-weight: 700;
  white-space: nowrap;
  transition: opacity 0.2s;
}
.kg-pill.hidden { opacity: 0; pointer-events: none; }
.kg-pill.murojaah {
  background: transparent;
  color: var(--abu-tua);
  border: 1.5px dashed var(--abu-tua);
}

.arab-text {
  font-family: 'Traditional Arabic', 'Scheherazade New', 'Amiri', serif;
  font-size: 1.35rem;
  line-height: 1.8;
  color: var(--teks);
  text-align: center;
  direction: rtl;
}

.kode-rujukan {
  font-size: 0.62rem;
  color: var(--emas);
  background: var(--emas-pale);
  border: 1px solid var(--emas-border);
  border-radius: 3px;
  padding: 0 4px;
  font-weight: 700;
  transition: opacity 0.2s;
  min-height: 15px;
  min-width: 14px;
  text-align: center;
}
.kode-rujukan.hidden { opacity: 0; pointer-events: none; }

/* NOMOR AYAT — lingkaran besar sejajar baris kata */
.nomor-ayat {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  border: 2px solid var(--emas-border);
  color: var(--emas);
  font-family: 'Traditional Arabic', serif;
  font-size: 1.05rem;
  font-weight: 700;
  flex-shrink: 0;
  align-self: flex-start;
  margin-top: 28px;
  transition: opacity 0.2s;
}
.nomor-ayat.hidden { opacity: 0; pointer-events: none; width: 0; }

/* KODE RUJUKAN (KR) — kotak kecil di bawah Arab, menempel naik (overlap) */
.rujukan-row {
  display: flex;
  flex-direction: row;
  gap: 2px;
  justify-content: center;
  align-items: center;
  min-height: 18px;
}
.rujukan-target {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 16px;
  height: 16px;
  border: 1.5px solid var(--emas);
  border-radius: 3px;
  font-size: 0.6rem;
  font-weight: bold;
  color: var(--emas);
  background: var(--putih);
  transition: opacity 0.2s;
}
.rujukan-dhamir {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 16px;
  height: 16px;
  border: 1.5px solid #4a7a4a;
  border-radius: 3px;
  font-size: 0.56rem;
  font-weight: bold;
  color: #4a7a4a;
  background: #f0f7f0;
  transition: opacity 0.2s;
}
.rujukan-row.hidden { opacity: 0; pointer-events: none; }

.pegon-text {
  font-size: 0.67rem;
  color: #1a4a8a;
  text-align: center;
  direction: rtl;
  font-family: 'Traditional Arabic', serif;
  line-height: 1.5;
  transition: opacity 0.2s;
}
.pegon-text.ltr {
  direction: ltr;
  font-family: 'Segoe UI', sans-serif;
  font-style: italic;
  color: #555;
  font-size: 0.6rem;
}
.pegon-text.hidden { opacity: 0; pointer-events: none; }

.pegon-jawa-text {
  font-size: 0.67rem;
  color: #7c3aed;
  text-align: center;
  direction: rtl;
  font-family: 'Traditional Arabic', serif;
  line-height: 1.5;
  transition: opacity 0.2s;
}
.pegon-jawa-text.hidden { opacity: 0; pointer-events: none; }

/* IRAB */
.irab-text {
  font-family: 'Traditional Arabic', 'Scheherazade New', serif;
  font-size: 0.7rem;
  color: var(--emas);
  text-align: center;
  direction: rtl;
  line-height: 1.5;
  transition: opacity 0.2s;
  border-top: 1px dashed var(--emas-border);
  padding-top: 2px;
  margin-top: 2px;
  width: 100%;
}
.irab-text.hidden { opacity: 0; pointer-events: none; }

/* CATATAN NAHWU */
.catatan-wrap {
  margin-top: 6px;
  background: var(--emas-pale);
  border-right: 3px solid var(--emas-md);
  border-radius: 0 6px 6px 0;
  padding: 8px 10px;
  direction: rtl;
  font-size: 0.74rem;
  color: #5a4500;
}
.catatan-wrap.hidden { display: none; }
.catatan-label {
  font-weight: 700;
  font-size: 0.63rem;
  margin-bottom: 3px;
  color: var(--emas);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.cat-edit-btn {
  display: none;
  cursor: pointer;
  font-size: 0.68rem;
  color: var(--emas);
  border: 1px solid var(--emas);
  border-radius: 4px;
  padding: 1px 5px;
}
.kal-gabung-btn {
  display: none;
  cursor: pointer;
  font-size: 0.68rem;
  color: #7c3aed;
  border: 1px solid #7c3aed;
  border-radius: 4px;
  padding: 1px 6px;
  background: #f5f3ff;
}

/* ===== MODAL ===== */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: none;
  align-items: flex-end;
  justify-content: center;
}
.modal-overlay.show { display: flex; }
.modal-overlay.center { align-items: center; }

.modal {
  background: var(--putih);
  border-radius: 16px 16px 0 0;
  padding: 20px;
  width: 100%;
  max-width: 600px;
  max-height: 90vh;
  overflow-y: auto;
  direction: rtl;
}
.modal.center-modal {
  border-radius: 14px;
  max-width: 440px;
  max-height: 85vh;
}

.modal-title {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--hijau);
  margin-bottom: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.modal-close {
  background: none; border: none;
  font-size: 1.1rem; cursor: pointer;
  color: var(--abu-tua);
}
.modal-preview {
  font-family: 'Traditional Arabic', serif;
  font-size: 1.6rem;
  text-align: center;
  padding: 10px;
  background: var(--abu);
  border-radius: 8px;
  margin-bottom: 14px;
  direction: rtl;
}
.field-group { margin-bottom: 12px; }
.field-label {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--abu-tua);
  margin-bottom: 4px;
  display: block;
}
.field-input {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  padding: 8px 10px;
  font-size: 0.85rem;
  outline: none;
  transition: border-color 0.2s;
  font-family: inherit;
}
.field-input:focus { border-color: var(--hijau); }

.file-picker-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
  cursor: pointer;
  background: var(--putih);
  font-size: 0.8rem;
  color: var(--abu-tua);
  gap: 8px;
}
.file-picker-label:active { background: var(--abu); }
.file-picker-btn {
  background: var(--abu);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 6px 12px;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--hijau);
  white-space: nowrap;
  flex-shrink: 0;
}
.field-input.arab {
  font-family: 'Traditional Arabic', serif;
  font-size: 1.1rem;
  direction: rtl;
  text-align: right;
}
.field-input.pegon {
  font-family: 'Traditional Arabic', serif;
  direction: rtl;
  text-align: right;
}
.field-input.irab-input {
  font-family: 'Traditional Arabic', serif;
  font-size: 0.95rem;
  direction: rtl;
  text-align: right;
}
.field-textarea {
  width: 100%;
  min-height: 80px;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  padding: 8px 10px;
  font-size: 0.82rem;
  outline: none;
  resize: vertical;
  direction: rtl;
  font-family: inherit;
}
.field-textarea:focus { border-color: var(--hijau); }

.modal-btns {
  display: flex;
  gap: 8px;
  margin-top: 16px;
  flex-wrap: wrap;
}
.btn-save {
  flex: 1;
  background: var(--hijau);
  color: white;
  border: none;
  border-radius: 8px;
  padding: 12px;
  font-size: 0.88rem;
  font-weight: 700;
  cursor: pointer;
  min-width: 80px;
}
.btn-cancel {
  background: var(--putih);
  color: var(--abu-tua);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 12px 20px;
  font-size: 0.85rem;
  cursor: pointer;
}
.btn-del {
  background: var(--merah-pale);
  color: var(--merah);
  border: 1px solid #fca5a5;
  border-radius: 8px;
  padding: 12px 14px;
  font-size: 0.82rem;
  cursor: pointer;
}

/* IMPORT JSON AREA */
.import-area {
  width: 100%;
  min-height: 80px;
  border: 1.5px dashed var(--border);
  border-radius: 8px;
  padding: 10px;
  font-size: 0.7rem;
  font-family: monospace;
  direction: ltr;
  resize: vertical;
  outline: none;
  color: #374151;
}
.import-area:focus { border-color: var(--hijau); border-style: solid; }

/* KONFIRMASI */
.konfirm-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.konfirm-overlay.show { display: flex; }
.konfirm-box {
  background: var(--putih);
  border-radius: 14px;
  padding: 22px;
  max-width: 340px;
  width: 100%;
  direction: rtl;
}
.konfirm-title { font-size: 0.9rem; font-weight: 700; color: var(--merah); margin-bottom: 8px; }
.konfirm-msg { font-size: 0.78rem; color: #374151; margin-bottom: 16px; line-height: 1.6; }
.konfirm-btns { display: flex; gap: 8px; }
.btn-konfirm-ya {
  flex: 1; background: var(--merah); color: white;
  border: none; border-radius: 8px; padding: 10px;
  font-size: 0.85rem; font-weight: 700; cursor: pointer;
}
.btn-konfirm-tidak {
  flex: 1; background: var(--putih); color: var(--abu-tua);
  border: 1px solid var(--border); border-radius: 8px; padding: 10px;
  font-size: 0.85rem; cursor: pointer;
}

/* TOAST */
.toast {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: var(--hijau);
  color: white;
  border-radius: 8px;
  padding: 10px 20px;
  font-size: 0.82rem;
  z-index: 300;
  opacity: 0;
  transition: all 0.25s;
  pointer-events: none;
  white-space: nowrap;
  direction: rtl;
}
.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* EXPORT AREA */
