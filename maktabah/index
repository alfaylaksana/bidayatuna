}

async function simpanKitab() {
  const judulArab = document.getElementById('fJudulArab').value.trim();
  const judulIndo = document.getElementById('fJudulIndo').value.trim();
  if (!judulArab && !judulIndo) {
    toast('⚠️ Judul kitab harus diisi.');
    return;
  }
  try {
    if (modalKitabMode === 'tambah') {
      const kitabBaru = {
        id:          'kitab_' + Date.now(),
        judulArab,
        judulIndo,
        pengarang:   document.getElementById('fPengarang').value.trim(),
        tahun:       document.getElementById('fTahun').value.trim(),
        bidang:      document.getElementById('fBidang').value,
        keterangan:  document.getElementById('fKeterangan').value.trim(),
        halaman:     [],
        dibuatPada:  new Date().toISOString(),
      };
      await dbPut(kitabBaru);
      koleksi.push(kitabBaru);
      toast('✅ Kitab berhasil ditambahkan.');
    } else {
      const k = koleksi.find(x => x.id === editKitabId);
      if (!k) return;
      k.judulArab  = judulArab;
      k.judulIndo  = judulIndo;
      k.pengarang  = document.getElementById('fPengarang').value.trim();
      k.tahun      = document.getElementById('fTahun').value.trim();
      k.bidang     = document.getElementById('fBidang').value;
      k.keterangan = document.getElementById('fKeterangan').value.trim();
      await dbPut(k);
      toast('✅ Info kitab diperbarui.');
    }
    closeModal('modalKitab');
    renderDaftar();
  } catch(err) {
    toast('❌ Gagal simpan: ' + (err && err.message ? err.message : err));
    console.error('simpanKitab error:', err);
  }
}

// ============================================================
// HAPUS KITAB
// ============================================================
function hapusKitab(id) {
  const k = koleksi.find(x => x.id === id);
  if (!k) return;
  konfirm(
    'Hapus Kitab?',
    `"${k.judulIndo || k.judulArab}" akan dihapus permanen dari arsip. Tindakan ini tidak bisa dibatalkan.`,
    async () => {
      await dbDelete(id);
      koleksi = koleksi.filter(x => x.id !== id);
      renderDaftar();
      toast('🗑 Kitab berhasil dihapus.');
    }
  );
}

