<!-- ===== SCRIPT ===== -->
<script type="module">
// ============================================================
// FIREBASE FIRESTORE
// ============================================================
import { initializeApp } from "https://www.gstatic.com/firebasejs/11.2.0/firebase-app.js";
import { getFirestore, collection, doc, getDocs, setDoc, deleteDoc } from "https://www.gstatic.com/firebasejs/11.2.0/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyAJVB25E2Oq6bEq5AkkTydGsLZ23dURj_Y",
  authDomain: "bidayatuna-836e4.firebaseapp.com",
  projectId: "bidayatuna-836e4",
  storageBucket: "bidayatuna-836e4.firebasestorage.app",
  messagingSenderId: "666248558558",
  appId: "1:666248558558:web:d55a1a4583faf26c190f4f"
};

const firebaseApp = initializeApp(firebaseConfig);
const db = getFirestore(firebaseApp);
const KOLEKSI = collection(db, 'maktabah');

async function dbGetAll() {
  const snap = await getDocs(KOLEKSI);
  return snap.docs.map(d => d.data());
}

async function dbPut(obj) {
  const ref = doc(db, 'maktabah', obj.id);
  await setDoc(ref, obj);
}

async function dbDelete(id) {
  const ref = doc(db, 'maktabah', id);
  await deleteDoc(ref);
}

// ============================================================
// STATE
// ============================================================
let koleksi     = [];   // array semua kitab
let kitabAktif  = null; // kitab yang sedang dibaca
let editMode    = false;
let editTarget  = null;
let catatanTarget = null;
let harakatOn   = true;
let irobOnly    = false;
const togState  = { kode:true, pegon:true, pegonjawa:true, indo:true, irab:true, catatan:true, rujukan:true };
let modalKitabMode = 'tambah'; // 'tambah' | 'edit'
let editKitabId = null;
let konfirmCb   = null;
let perubahanBelumExport = 0;
let reminderTimer = null;
const BATAS_PERUBAHAN = 5;      // tampilkan reminder setelah 5x edit
const BATAS_WAKTU_MS  = 10 * 60 * 1000; // atau 10 menit, mana yang lebih dulu

// ============================================================
// EXPOSE FUNGSI KE WINDOW (diperlukan karena type="module")
// ============================================================
window.bukaKitab        = bukaKitab;
window.bukaModalImport  = bukaModalImport;
window.bukaModalTambah  = bukaModalTambah;
window.closeKonfirm     = closeKonfirm;
window.closeModal       = closeModal;
window.copyExport       = copyExport;
window.deleteKata       = deleteKata;
window.editKitabMeta    = editKitabMeta;
window.exportKitab      = exportKitab;
window.gabungKalimat    = gabungKalimat;
window.hapusKitab       = hapusKitab;
window.kembaliDaftar    = kembaliDaftar;
window.openCatatan      = openCatatan;
window.pilihSumberImport = pilihSumberImport;
window.prosesImport     = prosesImport;
window.saveCatatan      = saveCatatan;
window.saveKata         = saveKata;
window.simpanKitab      = simpanKitab;
window.togHarakat       = togHarakat;
window.togIrob          = togIrob;
window.togView          = togView;
window.toggleEditMode   = toggleEditMode;
window.updatePreview    = updatePreview;
window.bacaFileImport   = bacaFileImport;
window.openKata         = openKata;

// ============================================================
// INIT
// ============================================================
async function init() {
  try {
    toast('⏳ Memuat data dari server...');
    koleksi = await dbGetAll();
    renderDaftar();
  } catch(err) {
    toast('❌ Gagal memuat data: ' + (err && err.message ? err.message : err));
    console.error('init error:', err);
  }
}
init();

// ============================================================
// DAFTAR KITAB
// ============================================================
function renderDaftar() {
  const wrap = document.getElementById('daftarKitab');
  document.getElementById('jumlahKitab').textContent = koleksi.length + ' kitab';

  if (!koleksi.length) {
    wrap.innerHTML = `
      <div class="empty-state">
        <span class="icon">المكتبة</span>
        <h2>Perpustakaan masih kosong</h2>
        <p>Tekan <strong>＋ Tambah Kitab</strong> untuk mendaftarkan kitab baru,<br>lalu import halaman dari Ar-Risalah Instan.</p>
      </div>`;
    return;
  }

  wrap.innerHTML = '<div class="grid-kitab" id="gridKitab"></div>';
  const grid = document.getElementById('gridKitab');
  koleksi.forEach(k => {
    const jml = (k.halaman||[]).length;
    const badgeClass = 'badge-' + (k.bidang || 'lain');
    const card = document.createElement('div');
    card.className = 'kartu-kitab';
    card.innerHTML = `
      <div class="kartu-spine"></div>
      <div class="kartu-body">
        <div class="kartu-arab">${k.judulArab || '—'}</div>
        <div class="kartu-judul">${k.judulIndo || '—'}</div>
        <div class="kartu-meta">
          ${k.pengarang ? k.pengarang + '<br>' : ''}
          ${k.tahun || ''}
        </div>
        <div>
          <span class="badge-bidang ${badgeClass}">${k.bidang || 'lain'}</span>
          <span class="kartu-badge">${jml} halaman</span>
        </div>
      </div>
      <div class="kartu-actions">
        <button class="btn-kartu buka" onclick="bukaKitab('${k.id}')">📖 Buka</button>
        <button class="btn-kartu"      onclick="editKitabMeta('${k.id}')">✏️ Edit Info</button>
        <button class="btn-kartu hapus" onclick="hapusKitab('${k.id}')">🗑</button>
      </div>`;
    grid.appendChild(card);
  });
}

// ============================================================
// BUKA / KEMBALI
// ============================================================
function bukaKitab(id) {
  kitabAktif = koleksi.find(k => k.id === id);
  if (!kitabAktif) return;
  document.getElementById('halamanDaftar').style.display = 'none';
  document.getElementById('halamanBaca').style.display   = 'block';
  document.getElementById('bacaJudulArab').textContent   = kitabAktif.judulArab  || '—';
  document.getElementById('bacaJudulLatin').textContent  = kitabAktif.judulIndo  || '—';
  editMode = false;
  harakatOn = true; irobOnly = false;
  matikanReminder();
  resetTogUI();
  buildDisplay();
  window.scrollTo({top:0, behavior:'smooth'});
}

function kembaliDaftar() {
  kitabAktif = null;
  document.getElementById('halamanDaftar').style.display = 'block';
  document.getElementById('halamanBaca').style.display   = 'none';
  document.getElementById('exportWrap').classList.remove('show');
  matikanReminder();
  renderDaftar();
}

function resetTogUI() {
  Object.keys(togState).forEach(k => {
    togState[k] = true;
    const el = document.getElementById('tog-' + k);
    if (el) el.classList.add('on');
  });
  document.getElementById('tog-harakat').classList.add('on');
  document.getElementById('tog-irob').classList.remove('on');
  document.getElementById('btnEditMode').textContent = '✏️ Mode Edit';
  document.getElementById('btnEditMode').classList.remove('edit-mode');
}

// ============================================================
// BUILD DISPLAY
// ============================================================
function buildDisplay() {
  const wrap = document.getElementById('bacaContent');
  wrap.innerHTML = '';
  const halaman = kitabAktif ? (kitabAktif.halaman || []) : [];

  if (!halaman.length) {
    wrap.innerHTML = `
      <div style="padding:40px;text-align:center;color:var(--abu-tua)">
        <div style="font-size:2rem;margin-bottom:10px">📭</div>
        <div style="font-size:0.85rem">Belum ada halaman.<br>Tekan <strong>📥 Import Halaman</strong> untuk menambahkan data dari Ar-Risalah Instan.</div>
      </div>`;
    return;
  }

  halaman.forEach((hlm, hi) => {
    const block = document.createElement('div');
    block.className = 'halaman-block';

    const lbl = document.createElement('div');
    lbl.className = 'halaman-label';
    lbl.textContent = `الصفحة ${hi + 1}` + (hlm.judul_bab ? ` — ${hlm.judul_bab}` : '');
    block.appendChild(lbl);

    if (hlm.judul_bab) {
      const bab = document.createElement('div');
      bab.className = 'bab-title';
      bab.textContent = hlm.judul_bab;
      block.appendChild(bab);
    }

    (hlm.kalimat || []).forEach((kal, ki) => {
      const kWrap = document.createElement('div');
      kWrap.className = 'kalimat-wrap';

      (kal.kata || []).forEach((k, wi) => {
        kWrap.appendChild(buildKataUnit(k, hi, ki, wi));
        if (k.rujukan) {
          const nomorEl = document.createElement('span');
          nomorEl.className = 'nomor-ayat' + (togState.rujukan ? '' : ' hidden');
          nomorEl.textContent = k.rujukan;
          kWrap.appendChild(nomorEl);
        }
      });
      block.appendChild(kWrap);

      // Catatan Nahwu
      const isLastKal = ki === (hlm.kalimat.length - 1);
      const cat = document.createElement('div');
      cat.className = 'catatan-wrap' + (togState.catatan ? '' : ' hidden');
      cat.innerHTML = `
        <div class="catatan-label">
          📝 Catatan Nahwu
          <span style="display:flex;gap:5px;align-items:center">
            <span class="kal-gabung-btn" id="gabungBtn_${hi}_${ki}"
              onclick="gabungKalimat(${hi},${ki})"
              style="display:${editMode && !isLastKal ? 'inline' : 'none'}">⤵ Gabung ↓</span>
            <span class="cat-edit-btn" id="catBtn_${hi}_${ki}"
              onclick="openCatatan(${hi},${ki})"
              style="display:${editMode ? 'inline' : 'none'}">✏️ Edit</span>
          </span>
        </div>
        <span class="catatan-isi">${kal.catatan_nahwu || '—'}</span>`;
      block.appendChild(cat);
    });

    wrap.appendChild(block);
  });

  applyHarakatMode();
}

function buildKataUnit(k, hi, ki, wi) {
  const unit = document.createElement('div');
  unit.className = 'kata-unit' + (editMode ? ' edit-active' : '');
  unit.dataset.hi = hi; unit.dataset.ki = ki; unit.dataset.wi = wi;
  if (editMode) unit.onclick = () => openKata(hi, ki, wi);

  // Kode Gramatikal — pills
  const kgWrap = document.createElement('div');
  kgWrap.className = 'kode-gram-wrap';
  const kodes = (k.kode_gram || '').split(/[\s\/]+/).filter(Boolean);
  if (kodes.length) {
    kodes.forEach(kg => {
      const pill = document.createElement('span');
      pill.className = 'kg-pill' + (togState.kode ? '' : ' hidden') + (/^\.{2,}$/.test(kg) ? ' murojaah' : '');
      pill.textContent = kg;
      kgWrap.appendChild(pill);
    });
  } else {
    // Tidak ada kode gramatikal — biarkan kosong, jangan tampilkan placeholder
  }
  unit.appendChild(kgWrap);

  // Arab
  const ar = document.createElement('div');
  ar.className = 'arab-text';
  ar.dataset.orig = k.arab || '';
  ar.textContent = k.arab || '';
  unit.appendChild(ar);

  // Kode Rujukan (KR) — kotak target & dhamir, di bawah Arab
  const rrow = document.createElement('div');
  rrow.className = 'rujukan-row' + (togState.rujukan ? '' : ' hidden');
  let adaRujukan = false;
  if (k.kr_target) {
    const rt = document.createElement('div');
    rt.className = 'rujukan-target';
    rt.textContent = k.kr_target;
    rrow.appendChild(rt);
    adaRujukan = true;
  }
  if (k.kr_dhamir) {
    const rd = document.createElement('div');
    rd.className = 'rujukan-dhamir';
    rd.textContent = '→' + k.kr_dhamir;
    rrow.appendChild(rd);
    adaRujukan = true;
  }
  if (!adaRujukan) rrow.style.visibility = 'hidden';
  unit.appendChild(rrow);

  // Pegon
  const pg = document.createElement('div');
  pg.className = 'pegon-text' + (togState.pegon ? '' : ' hidden');
  pg.textContent = k.pegon || '';
  unit.appendChild(pg);

  // Pegon Jawa
  const pgj = document.createElement('div');
  pgj.className = 'pegon-jawa-text' + (togState.pegonjawa ? '' : ' hidden');
  pgj.textContent = k.pegonJawa || '';
  if (!k.pegonJawa) pgj.style.display = 'none';
  unit.appendChild(pgj);

  // Terjemah Indo
  const id = document.createElement('div');
  id.className = 'pegon-text ltr' + (togState.indo ? '' : ' hidden');
  id.textContent = k.indo || '';
  unit.appendChild(id);

  // الإعراب
  const ib = document.createElement('div');
  ib.className = 'irab-text' + (togState.irab ? '' : ' hidden');
  ib.textContent = k.irab || '';
  if (!k.irab) ib.style.display = 'none';
  unit.appendChild(ib);

  return unit;
}

