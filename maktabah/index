}

function editKitabMeta(id) {
  const k = koleksi.find(x => x.id === id);
  if (!k) return;
  modalKitabMode = 'edit';
  editKitabId = id;
  document.getElementById('modalKitabTitle').textContent = '✏️ Edit Info Kitab';
  document.getElementById('fJudulArab').value   = k.judulArab   || '';
  document.getElementById('fJudulIndo').value   = k.judulIndo   || '';
  document.getElementById('fPengarang').value   = k.pengarang   || '';
  document.getElementById('fTahun').value       = k.tahun       || '';
