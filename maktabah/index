let sumberImport = 'instan';
let isiFileImport = null;

function bukaModalImport() {
  document.getElementById('importFile').value = '';
  document.getElementById('fileNamaTerpilih').textContent = 'Tidak ada file dipilih';
  document.getElementById('importError').style.display = 'none';
  isiFileImport = null;
  pilihSumberImport('instan');
  openModal('modalImport');
}

function pilihSumberImport(src) {
  sumberImport = src;
  document.getElementById('srcInstan').classList.toggle('on', src === 'instan');
  document.getElementById('srcArrisalah').classList.toggle('on', src === 'arrisalah');
  const lbl = document.getElementById('importLabel');
  if (src === 'instan') {
    lbl.textContent = 'Pilih file JSON dari Ar-Risalah Instan:';
  } else {
    lbl.textContent = 'Pilih file JSON Data Kitab Jadi (gandul-data.json):';
  }
}

function bacaFileImport(e) {
  const file = e.target.files[0];
  const errEl = document.getElementById('importError');
  errEl.style.display = 'none';
  isiFileImport = null;
  if (!file) { document.getElementById('fileNamaTerpilih').textContent = 'Tidak ada file dipilih'; return; }

  document.getElementById('fileNamaTerpilih').textContent = '📄 ' + file.name + ' (' + (file.size/1024).toFixed(1) + ' KB)';

  const reader = new FileReader();
  reader.onload = (ev) => {
    try {
      isiFileImport = JSON.parse(ev.target.result);
      document.getElementById('fileNamaTerpilih').textContent += ' ✓ valid JSON';
    } catch(err) {
      isiFileImport = null;
      errEl.textContent = 'File bukan JSON yang valid: ' + err.message;
      errEl.style.display = 'block';
    }
  };
  reader.onerror = () => {
    errEl.textContent = 'Gagal membaca file.';
    errEl.style.display = 'block';
  };
  reader.readAsText(file);
}

// Konversi format Ar-Risalah (gandul-data) -> format internal Maktabah (halaman/kalimat/kata)
// Memisahkan field "kode" Ar-Risalah persis seperti logic parseKode() di index.html Ar-Risalah:
// - token huruf hijaiyah / "..." (titik latihan)        -> Kode Gramatikal (KG)
// - token angka Arab murni, mis. "٢"                     -> KR Target (rujukan-target)
// - token angka Arab dalam kurung siku, mis. "[٢]"        -> KR Dhamir (rujukan-dhamir)
function pisahKodeGramRujukan(raw) {
  if (!raw) return { kg: '', krTarget: '', krDhamir: '' };
  const ANGKA_ARAB_MURNI = /^[٠١٢٣٤٥٦٧٨٩]+$/;
  const DHOMIR_ARAB      = /^\[[٠١٢٣٤٥٦٧٨٩]+\]$/;
  const tokens = raw.trim().split(/[\s,،]+/).filter(Boolean);
  const kgParts = [];
  let krTarget = null;
  let krDhamir = null;
  tokens.forEach(t => {
    if (DHOMIR_ARAB.test(t)) {
      krDhamir = t.replace(/[\[\]]/g, '');
    } else if (ANGKA_ARAB_MURNI.test(t)) {
      krTarget = t;
    } else {
      kgParts.push(t);   // termasuk huruf hijaiyah dan "..." soal latihan
    }
  });
  return { kg: kgParts.join(' '), krTarget: krTarget || '', krDhamir: krDhamir || '' };
}

function konversiArRisalah(data) {
  const halamanList = data.halamanList || [];
  const hasilHalaman = [];

  halamanList.forEach(h => {
    // Lewati halaman struktural/non-konten
    if (h.tipe === 'gambar' || h.tipe === 'judul' || h.tipe === 'profil' || h.tipe === 'daftarisi') {
      return;
    }
    const babList = h.babList || [];
    if (!babList.length) return;

    babList.forEach(bab => {
      const kataList = bab.kataList || [];
      if (!kataList.length) return;

      const kataKonversi = kataList.map(k => {
        const { kg, krTarget, krDhamir } = pisahKodeGramRujukan(k.kode || '');
        return {
          arab:       k.arab || '',
          kode_gram:  kg,
          kr_target:  krTarget,
          kr_dhamir:  krDhamir,
          pegon:      k.maknaIndo || '',
          pegonJawa:  k.maknaJawa || '',
          indo:       '',
          irab:       '',
          rujukan:    k.nomor || ''
        };
      });

      hasilHalaman.push({
        nama_kitab: data.judulKitab || '',
        judul_bab:  bab.namaBab || bab.babJudulIndo || '',
        kalimat: [
          { catatan_nahwu: '', kata: kataKonversi }
        ]
      });
    });
  });

  return hasilHalaman;
}

async function prosesImport(ganti) {
  const errEl = document.getElementById('importError');
  if (!isiFileImport) {
    errEl.textContent = 'Pilih file JSON terlebih dahulu.';
    errEl.style.display = 'block';
    return;
  }
  const parsed = isiFileImport;
  errEl.style.display = 'none';

  let tambahan;
  if (sumberImport === 'arrisalah') {
    if (!parsed.halamanList) {
      errEl.textContent = 'JSON ini tidak terlihat seperti format Ar-Risalah (tidak ada "halamanList").';
      errEl.style.display = 'block';
      return;
    }
    tambahan = konversiArRisalah(parsed);
    if (!tambahan.length) {
      errEl.textContent = 'Tidak ada halaman berisi teks (babList/kataList) yang bisa diimport dari file ini.';
      errEl.style.display = 'block';
      return;
    }
  } else {
    if (!parsed.halaman) {
      errEl.textContent = 'JSON ini tidak terlihat seperti format Instan (tidak ada "halaman").';
      errEl.style.display = 'block';
      return;
    }
    tambahan = parsed.halaman;
  }
  if (ganti) {
    kitabAktif.halaman = tambahan;
  } else {
    kitabAktif.halaman = (kitabAktif.halaman || []).concat(tambahan);
  }

  await simpanKitabAktif();
  closeModal('modalImport');
  tandaiPerubahan();
  buildDisplay();
  toast(`✅ ${tambahan.length} halaman berhasil di-import.`);
}

// ============================================================
// SIMPAN KITAB AKTIF
// ============================================================
async function simpanKitabAktif() {
  if (!kitabAktif) return;
  const idx = koleksi.findIndex(k => k.id === kitabAktif.id);
  if (idx >= 0) koleksi[idx] = kitabAktif;
  const ukuran = new Blob([JSON.stringify(kitabAktif)]).size;
  if (ukuran > 900000) {
    toast('⚠️ Data kitab mendekati batas ukuran Firestore (900KB). Pertimbangkan pisah jadi beberapa kitab.');
  }
  await dbPut(kitabAktif);
}

// ============================================================
// EXPORT
// ============================================================
function exportKitab() {
  if (!kitabAktif) return;
  const wrap = document.getElementById('exportWrap');
  document.getElementById('exportTA').value = JSON.stringify(kitabAktif, null, 2);
  wrap.classList.add('show');
  wrap.scrollIntoView({behavior:'smooth'});
  matikanReminder();
  toast('💾 Siap di-copy — tekan tombol "Copy Semua" lalu simpan ke file.');
}
function copyExport() {
  const ta = document.getElementById('exportTA');
  ta.select();
  document.execCommand('copy');
  toast('📋 JSON tersalin!');
}

// ============================================================
// REMINDER EXPORT
// ============================================================
function tandaiPerubahan() {
  perubahanBelumExport++;
  if (perubahanBelumExport >= BATAS_PERUBAHAN) {
    nyalakanReminder();
  }
  if (!reminderTimer) {
    reminderTimer = setTimeout(() => {
      nyalakanReminder();
    }, BATAS_WAKTU_MS);
  }
}
function nyalakanReminder() {
  const btn = document.querySelector('.export-btn');
  if (btn) btn.classList.add('reminder');
  toast('💾 Sudah ada perubahan — jangan lupa Export JSON untuk backup.');
}
function matikanReminder() {
  perubahanBelumExport = 0;
  if (reminderTimer) { clearTimeout(reminderTimer); reminderTimer = null; }
  const btn = document.querySelector('.export-btn');
  if (btn) btn.classList.remove('reminder');
}

