// ============================================================
// GABUNG KALIMAT
// ============================================================
function gabungKalimat(hi, ki) {
  const hlm = kitabAktif.halaman[hi];
  if (ki >= hlm.kalimat.length - 1) return;
  const kal1 = hlm.kalimat[ki];
  const kal2 = hlm.kalimat[ki + 1];
  kal1.kata = kal1.kata.concat(kal2.kata);
  if (kal2.catatan_nahwu) {
    kal1.catatan_nahwu = [kal1.catatan_nahwu, kal2.catatan_nahwu].filter(Boolean).join(' — ');
  }
  hlm.kalimat.splice(ki + 1, 1);
  simpanKitabAktif();
  tandaiPerubahan();
  buildDisplay();
  reapplyEditMode();
  toast('✅ Dua kalimat berhasil digabung.');
}

function reapplyEditMode() {
  if (!editMode) return;
  document.querySelectorAll('.kata-unit').forEach(u => {
    u.classList.add('edit-active');
    const h = +u.dataset.hi, k = +u.dataset.ki, w = +u.dataset.wi;
    u.onclick = () => openKata(h, k, w);
  });
  document.querySelectorAll('.cat-edit-btn').forEach(b => b.style.display = 'inline');
  document.querySelectorAll('.kal-gabung-btn').forEach(b => {
    const hi = +b.id.split('_')[1];
    const ki = +b.id.split('_')[2];
    const hlm = kitabAktif ? kitabAktif.halaman[hi] : null;
    const isLast = hlm ? ki >= hlm.kalimat.length - 1 : true;
    b.style.display = (editMode && !isLast) ? 'inline' : 'none';
  });
}

