function togView(key) {
  togState[key] = !togState[key];
  document.getElementById('tog-' + key).classList.toggle('on', togState[key]);
  const show = togState[key];

  if (key === 'kode') {
    document.querySelectorAll('.kg-pill').forEach(e => e.classList.toggle('hidden', !show));
  } else if (key === 'pegon') {
    document.querySelectorAll('.pegon-text:not(.ltr)').forEach(e => e.classList.toggle('hidden', !show));
  } else if (key === 'pegonjawa') {
    document.querySelectorAll('.pegon-jawa-text').forEach(e => {
      if (e.textContent) e.classList.toggle('hidden', !show);
    });
  } else if (key === 'indo') {
    document.querySelectorAll('.pegon-text.ltr').forEach(e => e.classList.toggle('hidden', !show));
  } else if (key === 'irab') {
    document.querySelectorAll('.irab-text').forEach(e => {
      if (e.textContent) e.classList.toggle('hidden', !show);
    });
  } else if (key === 'catatan') {
    document.querySelectorAll('.catatan-wrap').forEach(e => e.classList.toggle('hidden', !show));
  } else if (key === 'rujukan') {
    document.querySelectorAll('.nomor-ayat').forEach(e => e.classList.toggle('hidden', !show));
    document.querySelectorAll('.rujukan-row').forEach(e => e.classList.toggle('hidden', !show));
  }
}

function togHarakat() {
  harakatOn = !harakatOn; irobOnly = false;
  document.getElementById('tog-harakat').classList.toggle('on', harakatOn);
  document.getElementById('tog-irob').classList.remove('on');
  applyHarakatMode();
}
function togIrob() {
  irobOnly = !irobOnly;
  if (irobOnly) harakatOn = false;
  document.getElementById('tog-irob').classList.toggle('on', irobOnly);
  document.getElementById('tog-harakat').classList.toggle('on', !irobOnly && harakatOn);
  applyHarakatMode();
}
function applyHarakatMode() {
  document.querySelectorAll('.arab-text').forEach(el => {
    const orig = el.dataset.orig || '';
    if (harakatOn) {
      el.textContent = orig;
    } else if (irobOnly) {
      el.textContent = stripHarakatKeepIrab(orig);
    } else {
      el.textContent = stripAllHarakat(orig);
    }
  });
}
function stripAllHarakat(s) {
  return s.replace(/[\u064B-\u065F\u0670]/g, '');
}
function stripHarakatKeepIrab(s) {
  // Hapus semua harakat kecuali harakat akhir (posisi sebelum spasi/akhir string)
  return s.replace(/([\u0621-\u06FF])([\u064B-\u065F\u0670]+)(?=[^\u064B-\u065F\u0670\u0621-\u06FF]|$)/g, (m, huruf, harakat) => huruf + harakat)
           .replace(/([\u0621-\u06FF])([\u064B-\u065F\u0670]+)(?=[\u0621-\u06FF])/g, (m, huruf) => huruf);
}

