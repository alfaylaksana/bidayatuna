function bukaModalTambah() {
  modalKitabMode = 'tambah';
  editKitabId = null;
  document.getElementById('modalKitabTitle').textContent = '📚 Tambah Kitab';
  ['fJudulArab','fJudulIndo','fPengarang','fTahun','fKeterangan'].forEach(id => {
