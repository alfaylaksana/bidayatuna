function openKata(hi, ki, wi) {
  if (!editMode || !kitabAktif) return;
  editTarget = {hi, ki, wi};
  const k = kitabAktif.halaman[hi].kalimat[ki].kata[wi];
  document.getElementById('editArab').value    = k.arab    || '';
  document.getElementById('editKode').value    = k.kode_gram || '';
  document.getElementById('editPegon').value   = k.pegon   || '';
  document.getElementById('editPegonJawa').value = k.pegonJawa || '';
  document.getElementById('editIndo').value    = k.indo    || '';
  document.getElementById('editIrab').value    = k.irab    || '';
  document.getElementById('editKrTarget').value = k.kr_target || '';
  document.getElementById('editKrDhamir').value = k.kr_dhamir || '';
  document.getElementById('editRujukan').value = k.rujukan || '';
  document.getElementById('modalPreview').textContent = k.arab || '—';
  openModal('modalKata');
}
function updatePreview() {
  document.getElementById('modalPreview').textContent = document.getElementById('editArab').value || '—';
}
function saveKata() {
  if (!editTarget || !kitabAktif) return;
  const {hi, ki, wi} = editTarget;
  const k = kitabAktif.halaman[hi].kalimat[ki].kata[wi];
  k.arab     = document.getElementById('editArab').value.trim();
  k.kode_gram = document.getElementById('editKode').value.trim();
  k.pegon    = document.getElementById('editPegon').value.trim();
  k.pegonJawa = document.getElementById('editPegonJawa').value.trim();
  k.indo     = document.getElementById('editIndo').value.trim();
  k.irab     = document.getElementById('editIrab').value.trim();
  k.kr_target = document.getElementById('editKrTarget').value.trim();
  k.kr_dhamir = document.getElementById('editKrDhamir').value.trim();
  k.rujukan  = document.getElementById('editRujukan').value.trim();
  closeModal('modalKata');
  simpanKitabAktif();
  tandaiPerubahan();
  buildDisplay();
  reapplyEditMode();
}
function deleteKata() {
  if (!editTarget || !kitabAktif) return;
  const {hi, ki, wi} = editTarget;
  kitabAktif.halaman[hi].kalimat[ki].kata.splice(wi, 1);
  closeModal('modalKata');
  simpanKitabAktif();
  tandaiPerubahan();
  buildDisplay();
  reapplyEditMode();
}

